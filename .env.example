# Poli-News — environment variables
# Copy to .env and fill in values

# ── Database ─────────────────────────────────────────────
POLINEWS_DB_PATH=data/polinews.db

# ── Auth (JWT) ───────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=change_me_generate_with_secrets_token_hex_32
JWT_ALGORITHM=HS256
JWT_EXPIRE_DAYS=7

# ── Magic link ───────────────────────────────────────────
MAGIC_LINK_EXPIRE_MINUTES=15
# Set to "log" to print link to stdout instead of sending email (dev mode)
MAGIC_LINK_DELIVERY=log
# Required only when MAGIC_LINK_DELIVERY=resend
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@polinews.io

# ── LLM provider ─────────────────────────────────────────
# Options: "ollama" | "openai"
LLM_PROVIDER=ollama

# Ollama (local)
OLLAMA_BASE_URL=http://localhost:11434
KEYPOINTS_MODEL=qwen2.5:3b
QUIZ_POOL_MODEL=qwen2.5:3b

# OpenAI (cloud) — used only when LLM_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_KEYPOINTS_MODEL=gpt-4o-mini
OPENAI_QUIZ_MODEL=gpt-4o-mini

# ── Ingestion ─────────────────────────────────────────────
DEFAULT_FEEDS_CSV=docs/mvp_offchain/specs/feed_registry_v1.csv
DEFAULT_LOG_DIR=logs
DEFAULT_STATE_PATH=data/stale_state.json
REQUEST_TIMEOUT_SECONDS=8
MAX_RETRIES=3
BACKOFF_SECONDS=1,3,9
STALE_THRESHOLD=3
DEDUP_WINDOW_HOURS=24

KEYPOINTS_TIMEOUT_SECONDS=25
KEYPOINTS_MAX_RETRIES=2
KEYPOINTS_BACKOFF_SECONDS=1,3
KEYPOINTS_MAX_STORIES_PER_RUN=150

QUIZ_POOL_ENABLED=1
QUIZ_POOL_TIMEOUT_SECONDS=30
QUIZ_POOL_MAX_RETRIES=2
QUIZ_POOL_BACKOFF_SECONDS=1,3
QUIZ_POOL_MAX_STORIES_PER_RUN=150
QUIZ_POOL_TARGET_SIZE=10
QUIZ_POOL_MIN_SIZE=4
QUIZ_POOL_GENERATOR_VERSION=v1

# ── Scheduler ─────────────────────────────────────────────
# Interval in minutes between full collector runs
COLLECTOR_INTERVAL_MINUTES=15
# Jitter in seconds added/subtracted randomly to avoid thundering herd
COLLECTOR_JITTER_SECONDS=30

# ── API server ───────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
# Comma-separated allowed origins for CORS (use * for dev)
CORS_ORIGINS=*

# ── Publisher auth ───────────────────────────────────────
# Static API key for publisher dashboard endpoints (MVP simple auth)
PUBLISHER_API_KEY=change_me_publisher_key

# ── Rate limiting ────────────────────────────────────────
RATE_LIMIT_DEFAULT=60/minute
RATE_LIMIT_ATTEMPT=10/minute
